# OcuVision local-development configuration.
# Loaded automatically by dotenv when server.js starts.

# Absolute path to the MATLAB executable used to run uploaded .m / .mlx / .mat
# AI models. On Windows the installer puts it in:
#   C:\Program Files\MATLAB\<RELEASE>\bin\matlab.exe
# Replace <RELEASE> with the version installed on this machine (e.g. R2025b).
MATLAB_EXEC=C:\Program Files\MATLAB\R2025b\bin\matlab.exe

# Optional: how long (in milliseconds) to wait for MATLAB to finish before
# aborting. Defaults to 5 minutes if not set.
# MATLAB_TIMEOUT_MS=300000

# Optional: override the port the Express server listens on (defaults to 3000).
# PORT=3000

# Optional: enable Supabase as the persistence backend by setting both of these.
# When unset, the server falls back to local JSON files in ./data.
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
